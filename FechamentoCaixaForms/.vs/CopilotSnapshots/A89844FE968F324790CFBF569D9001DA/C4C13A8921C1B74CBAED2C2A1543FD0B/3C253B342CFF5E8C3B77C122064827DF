using System;
using System.Collections.Generic;
using FechamentoCaixa.DataBase;
using FechamentoCaixa.Entities;
using FechamentoCaixa.Exceptions;

namespace FechamentoCaixa.Service
{
    public class FechamentoFinalService
    {
        private readonly GerenciadorDatabase _db; // Injeção de dependência do banco de dados
        private readonly MotoqueiroService _motoqueiroService; // Serviço para obter informações dos motoqueiros
        public FechamentoFinalService(GerenciadorDatabase db)
        {
            _db = db;
            _motoqueiroService = new MotoqueiroService(_db);
        }
        // =====================================================
        // OBTÉM RESUMO DE FECHAMENTOS NO PERÍODO
        // =====================================================
        public List<ResumoFechamento> ObterFechamentosPeriodo(DateTime inicio, DateTime final)
        {
            inicio = inicio.Date;
            final = final.Date;

            if (inicio > final)
                throw new DataInicioMaiorException();

            var resumo = _db.ObterFechamentosPeriodo(inicio, final);

            if (resumo == null || resumo.Count == 0)
                throw new ResumoVazioException();

            return resumo;
        }

        // =====================================================
        // SALVA FECHAMENTO FINAL COMPLETO
        // =====================================================
        public void SalvarFechamentoFinal(DateTime dataInicio, DateTime dataFinal, List<FechamentoFinalItem> itens)
        {
            if (itens == null || itens.Count == 0)
                throw new Exception("Nenhum item para salvar.");

            var fechamento = new FechamentoFinal
            {
                DataInicio = dataInicio.Date,
                DataFinal = dataFinal.Date,
                Itens = itens
            };

            _db.SalvarFechamentoFinal(fechamento);
        }

        // =====================================================
        // CRIA ITEM INDIVIDUAL DO FECHAMENTO
        // =====================================================
        public FechamentoFinalItem CriarItemFechamentoFinal(
            ResumoFechamento resumo,
            decimal valeDescontado,
            decimal descontoExtra)
        {

            _motoqueiroService.VerificaValorValeDescontado(_motoqueiroService.BuscarMotoqueiroId(resumo.MotoqueiroId).Id, valeDescontado);
            if(descontoExtra < 0)
                throw new ValorDescontoNegativoException();
            if((descontoExtra + valeDescontado) > resumo.TotalGeral)
                throw new ValorMaiorQueTotalException();

            // Remove o vale do motoqueiro
            _motoqueiroService.RemoverValeMotoqueiro(
                resumo.MotoqueiroId,
                valeDescontado);

            decimal totalLiquido =
                resumo.TotalGeral - valeDescontado - descontoExtra;

            return new FechamentoFinalItem
            {
                MotoqueiroId = resumo.MotoqueiroId,
                Taxa5 = resumo.Taxa5,
                Taxa7 = resumo.Taxa7,
                Taxa10 = resumo.Taxa10,
                TotalFixo = resumo.TotalFixo,
                TotalBruto = resumo.TotalGeral,
                ValeDescontado = valeDescontado,
                DescontoExtra = descontoExtra,
                TotalLiquido = totalLiquido
            };
        }

        // =====================================================
        // VERIFICA SE JÁ EXISTE FECHAMENTO NAS DATAS INFORMADAS
        // =====================================================
        public void VerificarFechamentoExistente(DateTime inicio, DateTime final)
        {
            inicio = inicio.Date;
            final = final.Date;

            Console.WriteLine($"Inicio: {inicio}");
            Console.WriteLine($"Final: {final}");

            if (_db.ExisteFechamentoFinalNoPeriodo(inicio, final))
            {
                throw new FechamentoFinalExistenteException();
            }
        }
    }
}
